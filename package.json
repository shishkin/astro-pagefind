{
  "name": "root",
  "private": true,
  "engines": {
    "node": ">=18",
    "pnpm": "^11.0.0"
  },
  "scripts": {
    "dev": "pnpm run --filter=example dev",
    "lint": "eslint --ext .ts,.js,.astro .",
