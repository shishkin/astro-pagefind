{
  "name": "root",
  "private": true,
  "engines": {
    "node": ">=18",
    "pnpm": "^11.0.0"
  },
  "scripts": {
    "dev": "pnpm run --filter=example dev",
    "format:write": "pnpm exec biome format --write",
    "check": "pnpm exec biome check --error-on-warnings",
    "check:fix": "pnpm exec biome check --fix",
    "check:fix:staged": "pnpm exec biome check --fix --staged --no-errors-on-unmatched",
    "build:all": "pnpm run -r --if-present build",
    "build": "pnpm run \"/^(check|build:all)$/\"",
    "release": "pnpm run --filter=astro-pagefind release",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "husky": "9.1.7"
  },
  "packageManager": "pnpm@11.5.3",
  "homepage": "https://github.com/shishkin/astro-pagefind",
  "bugs": {
    "url": "https://github.com/shishkin/astro-pagefind/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shishkin/astro-pagefind.git"
  }
}