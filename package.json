    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "husky": "9.1.7"
  },
  "packageManager": "pnpm@11.0.8"
}
