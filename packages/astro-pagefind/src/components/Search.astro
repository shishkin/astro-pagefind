---
import PagefindConfig from "./PagefindConfig.astro";

export interface Props {
  instance?: string;
  className?: string;
  searchboxOptions?: Record<string, unknown>;
  configOptions?: Record<string, unknown>;
}

const { instance, className, searchboxOptions = {}, configOptions = {} } = Astro.props;
---

<PagefindConfig {...configOptions} instance={instance} />
<pagefind-searchbox
  {...searchboxOptions}
  instance={instance}
  class={className}
></pagefind-searchbox>
