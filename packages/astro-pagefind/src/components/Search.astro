---
import "@pagefind/component-ui/css/pagefind-component-ui.css";
import { join } from "node:path/posix";

export interface Props {
  readonly instance?: string;
  readonly className?: string;
  readonly searchboxOptions?: Record<string, any>;
  readonly configOptions?: Record<string, any>;
}

const { instance, className, searchboxOptions = {}, configOptions = {} } = Astro.props;
const bundlePath = join(import.meta.env.BASE_URL, "pagefind/");
---

<pagefind-config {...configOptions} instance={instance} bundle-path={bundlePath}></pagefind-config>
<pagefind-searchbox {...searchboxOptions} instance={instance} class={className}
></pagefind-searchbox>

<script>
  import "@pagefind/component-ui";
</script>
