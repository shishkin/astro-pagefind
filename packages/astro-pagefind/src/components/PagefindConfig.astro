---
import "@pagefind/component-ui/css/pagefind-component-ui.css";
import { join } from "node:path/posix";

export interface Props extends Record<string, unknown> {
  instance?: string | undefined;
}

const { instance, ...props } = Astro.props;
const bundlePath = join(import.meta.env.BASE_URL, "pagefind/");
---

<pagefind-config {...props} instance={instance} bundle-path={bundlePath}></pagefind-config>
<script>
  import "@pagefind/component-ui";
</script>
