{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "declaration": true,
    "moduleResolution": "bundler",
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": ["node_modules"]
}
