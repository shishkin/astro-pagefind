---
import PagefindConfig from "astro-pagefind/components/PagefindConfig.astro";
import Search from "astro-pagefind/components/Search.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width">
    <title>astro-pagefind</title>
  </head>
  <body>
    <header>
      <nav>
        <Search
          instance="search1"
          className="pagefind-yellow"
          searchboxOptions={{ placeholder: "find it..." }}
        />
      </nav>
    </header>
    <main>
      <slot />
      <PagefindConfig instance="search2" lang="en" preload={true} />
      <pagefind-searchbox instance="search2" class="pagefind-red"></pagefind-searchbox>
    </main>
  </body>
</html>
<style is:global>
  nav {
    display: grid;
    place-items: center;
  }

  .pagefind-yellow {
    --pf-background: lightyellow;
  }

  .pagefind-red {
    --pf-background: peachpuff;
  }
</style>
