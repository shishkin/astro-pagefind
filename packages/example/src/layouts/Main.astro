---
import Search from "astro-pagefind/components/Search";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>astro-pagefind</title>
  </head>
  <body>
    <header>
      <nav>
        <Search
          instance="search1"
          className="pagefind-ui yellow"
          searchboxOptions={{ placeholder: "find it..." }}
        />
      </nav>
    </header>
    <main>
      <slot />
      <Search instance="search2" className="pagefind-ui red" />
    </main>
  </body>
</html>
<style is:global>
  nav {
    display: grid;
    place-items: center;
  }

  .pagefind-ui.yellow {
    --pagefind-ui-background: lightyellow;
  }

  .pagefind-ui.red {
    --pagefind-ui-background: peachpuff;
    width: 100%;
  }
</style>
